{
  "name": "evolveme-app-base",
  "version": "1.0.0.3",
  "description": "A production-ready Expo template with TypeScript, NativeWind, i18n, authentication, and API client",
  "main": "expo-router/entry",
  "bin": {
    "evolveme-app-base": "./bin/create-expo-app.js"
  },
  "keywords": [
    "expo",
    "react-native",
    "template",
    "typescript",
    "nativewind",
    "tailwindcss",
    "expo-router",
    "authentication",
    "i18n",
    "starter",
    "boilerplate"
  ],
  "author": "Harry Viennot harryviennot@epitech.eu",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/harryviennot/create-expo-base-app.git"
  },
  "bugs": {
    "url": "https://github.com/harryviennot/create-expo-base-app/issues"
  },
  "homepage": "https://github.com/harryviennot/create-expo-base-app#readme",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "lint": "expo lint",
    "type-check": "tsc --noEmit",
    "format": "prettier --write \"src/**/*.{ts,tsx,json,md}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,json,md}\""
  },
